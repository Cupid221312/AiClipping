# ---------------------------------------------------------------------------
# Transcription (turning your video's speech into captions). Pick ONE.
# Copy this file to ".env" and fill in a key, then restart the app.
# ---------------------------------------------------------------------------

# EASIEST + FREE: Groq runs Whisper in the cloud, fast, no credit card.
# Get a free key at https://console.groq.com  ->  API Keys  ->  Create.
GROQ_API_KEY=

# Optional paid alternative: OpenAI Whisper + LLM clip-title polishing.
# https://platform.openai.com  (needs prepaid credit).
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# With NEITHER key set, the app still runs but shows a clearly-labeled
# PLACEHOLDER transcript (not your real audio). It can also use a local
# Whisper if you have the `whisper` CLI (pip install -U openai-whisper) or the
# optional @huggingface/transformers engine installed.
# ---------------------------------------------------------------------------

# Override models (optional):
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# WHISPER_MODEL=tiny.en
